                        { "key": "field_ccn_cta_btn_url", "label": "Button URL", "name": "button_url", "type": "text" }
                    ]
                },
                "layout_featured_products": {
                    "key": "layout_featured_products",
                    "name": "featured_products",
                    "label": "Featured products",
                    "display": "block",
                    "sub_fields": [
                        { "key": "field_ccn_fp_heading", "label": "Heading", "name": "heading", "type": "text" },
                        { "key": "field_ccn_fp_category", "label": "Category slug", "name": "category", "type": "text", "instructions": "Product category slug, or leave empty for featured products." },
                        { "key": "field_ccn_fp_count", "label": "Count", "name": "count", "type": "number", "default_value": 4, "min": 1, "max": 12 }
                    ]
                },
                "layout_news": {
                    "key": "layout_news",
                    "name": "news",
                    "label": "News",
                    "display": "block",
                    "sub_fields": [
