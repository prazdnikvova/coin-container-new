                        { "key": "field_ccn_hero_subtitle", "label": "Subtitle", "name": "subtitle", "type": "textarea", "rows": 2 },
                        { "key": "field_ccn_hero_image", "label": "Background image", "name": "image", "type": "image", "return_format": "id", "preview_size": "medium" },
                        { "key": "field_ccn_hero_btn_text", "label": "Button text", "name": "button_text", "type": "text" },
                        { "key": "field_ccn_hero_btn_url", "label": "Button URL", "name": "button_url", "type": "text" }
