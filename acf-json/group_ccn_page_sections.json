                        { "key": "field_ccn_intro_image", "label": "Image", "name": "image", "type": "image", "return_format": "id", "preview_size": "medium" },
                        { "key": "field_ccn_intro_btn_text", "label": "Button text", "name": "button_text", "type": "text" },
                        { "key": "field_ccn_intro_btn_url", "label": "Button URL", "name": "button_url", "type": "text" }
                    ]
