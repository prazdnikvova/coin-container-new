                "layout_text": {
                    "key": "layout_text",
                    "name": "text",
                    "label": "Text",
                    "display": "block",
                    "sub_fields": [
                        { "key": "field_ccn_text_heading", "label": "Heading", "name": "heading", "type": "text" },
